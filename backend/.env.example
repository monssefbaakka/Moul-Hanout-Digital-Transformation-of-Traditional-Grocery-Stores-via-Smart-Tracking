# ============================================================
# Backend Environment — Moul Hanout POS
# Copy this file to .env and fill in real values
# ============================================================

# ─── App ────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_NAME="Moul Hanout POS"
FRONTEND_URL=http://localhost:3000

# ─── Database ───────────────────────────────────────────────
# Standard PostgreSQL format (use this for production)
DATABASE_URL="postgresql://postgres:password@localhost:5432/moul_hanout?schema=public"

# ─── Auth ───────────────────────────────────────────────────
# Generate strong secrets: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_BASE64_64
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_FROM_JWT_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# ─── Redis (optional — for caching / session / queues) ──────
# REDIS_URL=redis://localhost:6379

# ─── Rate limiting (set via ThrottlerModule in AppModule) ───
# THROTTLE_TTL=60
# THROTTLE_LIMIT=100

# ─── Logging ────────────────────────────────────────────────
# LOG_LEVEL=debug
