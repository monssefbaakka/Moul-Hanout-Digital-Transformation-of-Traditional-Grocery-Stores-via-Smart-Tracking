# Backend environment for the Phase 1 foundation.

NODE_ENV=development
PORT=4000
APP_NAME="Moul Hanout"
FRONTEND_URL=http://localhost:3000

DATABASE_URL="postgresql://postgres:password@localhost:5432/moul_hanout?schema=public"

JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_BASE64_64
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_FROM_JWT_SECRET
