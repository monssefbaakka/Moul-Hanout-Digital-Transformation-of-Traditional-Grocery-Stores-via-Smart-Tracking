# ============================================================
# Frontend Environment — Moul Hanout POS
# NEXT_PUBLIC_ prefix = exposed to browser bundle
# ============================================================

# ─── API ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Moul Hanout"
NEXT_PUBLIC_APP_ENV=development

# ─── Auth ───────────────────────────────────────────────────
# Used server-side only by NextAuth / middleware
NEXTAUTH_SECRET=CHANGE_ME_USE_OPENSSL_RAND_BASE64_32
NEXTAUTH_URL=http://localhost:3000

# Enable demo credentials only in non-production environments.
NEXT_PUBLIC_ENABLE_DEMO_CREDENTIALS=false
# NEXT_PUBLIC_DEMO_EMAIL=owner@example.com
# NEXT_PUBLIC_DEMO_PASSWORD=CHANGE_ME

# ─── PWA / Analytics (optional) ─────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
